#. Plugin Name of the plugin
#: talaxie-core.php:3
#: src/Mcp/Server.php:134
msgid "Talaxie Core"
msgstr "Talaxie Core"

#. Plugin URI of the plugin
#: talaxie-core.php:4
msgid "https://github.com/eric-lemesre/talaxie-wp-core"
msgstr "https://github.com/eric-lemesre/talaxie-wp-core"

#. Description of the plugin
#: talaxie-core.php:5
msgid "Companion plugin for the Talaxie community website. Provides custom post types (releases, contributors), a \"component\" taxonomy, and the integration entry points with GitHub, Discord and Discourse."
msgstr "Plugin companion pour le site communautaire Talaxie. Fournit des types de contenu personnalisés (versions, contributeurs), une taxonomie \"composant\", et les points d'intégration avec GitHub, Discord et Discourse."

#. Author of the plugin
#: talaxie-core.php:9
msgid "Talaxie Community"
msgstr "Talaxie Community"

#. Author URI of the plugin
#: talaxie-core.php:10
msgid "https://talaxie.org"
msgstr "https://talaxie.org"

#: src/Mcp/Abilities/Audit/ListAudit.php:38
msgid "List MCP audit entries"
msgstr "Lister les entrées d'audit MCP"

#: src/Mcp/Abilities/Audit/ListAudit.php:39
msgid "Return the most recent MCP audit entries (allow/deny, capability, sudo usage). Requires manage_options."
msgstr "Retourne les dernières entrées d'audit MCP (autoriser/refuser, capacité, utilisation sudo). Nécessite manage_options."

#: src/Mcp/Abilities/Generic/RestCall.php:45
msgid "Forward to wp/v2 REST"
msgstr "Transférer vers wp/v2 REST"

#: src/Mcp/Abilities/Generic/RestCall.php:46
msgid "Forward an HTTP method + path to /wp-json/wp/v2/*. Capability is mapped per HTTP method. Test server only."
msgstr "Transfère une méthode HTTP + chemin vers /wp-json/wp/v2/*. La capacité est mappée par méthode HTTP. Serveur de test uniquement."

#: src/Mcp/Abilities/Generic/RestCall.php:58
msgid "Relative path inside wp/v2 (e.g. \"posts/123\" → /wp-json/wp/v2/posts/123)."
msgstr "Chemin relatif à l'intérieur de wp/v2 (par exemple, \"posts/123\" → /wp-json/wp/v2/posts/123)."

#: src/Mcp/Abilities/Generic/RestCall.php:82
msgid "Invalid path."
msgstr "Chemin invalide."

#: src/Mcp/Abilities/Media/DeleteMedia.php:38
msgid "Delete media"
msgstr "Supprimer les médias"

#: src/Mcp/Abilities/Media/DeleteMedia.php:39
msgid "Permanently delete an attachment and its files. Requires delete_posts (sudo token)."
msgstr "Supprime définitivement une pièce jointe et ses fichiers. Nécessite delete_posts (jeton sudo)."

