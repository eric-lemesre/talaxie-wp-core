msgid "Upload media"
msgstr "Téléverser des médias"

#: src/Mcp/Abilities/Media/UploadMedia.php:41
msgid "Create an attachment from a base64-encoded payload. Capability: upload_files."
msgstr "Crée une pièce jointe à partir d'une payload codée en base64. Capacité : upload_files."

