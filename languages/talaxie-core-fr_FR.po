msgid "This file type is not allowed by WordPress."
msgstr "Ce type de fichier n'est pas autorisé par WordPress."

#: src/Mcp/Abilities/Media/UploadMedia.php:90
msgid "Could not write the upload to disk."
msgstr "Impossible d'écrire le téléversement sur le disque."

