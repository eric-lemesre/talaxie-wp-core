msgid "Upload media"
msgstr "Medien hochladen"

#: src/Mcp/Abilities/Media/UploadMedia.php:41
msgid "Create an attachment from a base64-encoded payload. Capability: upload_files."
msgstr "Erstellt einen Anhang aus einer base64-kodierten Payload. Berechtigung: upload_files."

